generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum DealStage {
  LEAD
  CONTACTED
  PROPOSAL_SENT
  WON
  LOST
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ServiceType {
  SEO
  WEBSITE_DEVELOPMENT
  SOCIAL_MEDIA
  ADS
  CONTENT_MARKETING
  EMAIL_MARKETING
  OTHER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  COMPLETED
}

enum TaskType {
  MEETING
  FOLLOW_UP
  FEEDBACK
  ONBOARDING
  PAYMENT_REMINDER
  INVOICE
  SUBSCRIPTION
  CAMPAIGN
  CONTENT
  DEVELOPMENT
  DESIGN
  INTERNAL
  ALERT
}

enum TaskPriority {
  HIGH
  MEDIUM
  LOW
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
  OVERDUE
}

enum PaymentType {
  WEBSITE
  MARKETING
}

enum ActivityType {
  CALL
  MEETING
  NOTE
  EMAIL
  TASK_UPDATE
  STATUS_CHANGE
}

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  password       String
  name           String
  phone          String?
  role           UserRole       @default(USER)
  avatar         String?
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  refreshTokens  RefreshToken[]
  assignedTasks  Task[]         @relation("TaskAssignee")
  createdTasks   Task[]         @relation("TaskCreator")
  activities     Activity[]
  activityLogs   ActivityLog[]

  @@index([email])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model Client {
  id           String   @id @default(cuid())
  companyName  String
  ownerName    String
  email        String?
  phone        String
  services     String[]
  address      String?
  notes        String?
  isArchived   Boolean  @default(false)
  createdAt    DateTime @default(now())

  projects     Project[]
  deals        Deal[]
  activities   Activity[]
  payments     Payment[]
  tasks        Task[]
}

model Project {
  id             String        @id @default(cuid())
  name           String
  description    String?
  serviceType    ServiceType
  status         ProjectStatus @default(ACTIVE)
  startDate      DateTime?
  deadline       DateTime?
  budget         Float?
  value          Float?
  isRecurring    Boolean       @default(false)
  recurringMonth  Int?          // Day of month for recurring tasks (1-31)
  clientId       String?
  dealId         String?       @unique
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  client         Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  deal           Deal?         @relation(fields: [dealId], references: [id], onDelete: SetNull)
  tasks          Task[]
  activities     Activity[]
  payments       Payment[]

  @@index([clientId])
  @@index([dealId])
}

model Task {
  id             String        @id @default(cuid())
  title          String
  description    String?
  type           TaskType      @default(INTERNAL)
  priority       TaskPriority  @default(MEDIUM)
  status         TaskStatus    @default(TODO)
  dueDate        DateTime?
  isCompleted    Boolean       @default(false)
  projectId      String?
  assigneeId     String?
  creatorId      String
  clientId       String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  project        Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignee       User?         @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  creator        User          @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  client         Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  activities     Activity[]

  @@index([projectId])
  @@index([assigneeId])
  @@index([creatorId])
  @@index([clientId])
  @@index([type])
  @@index([priority])
  @@index([dueDate])
}

model Deal {
  id             String        @id @default(cuid())
  title          String
  description    String?
  stage          DealStage    @default(LEAD)
  value          Float?
  probability    Int?         // 0-100
  expectedCloseDate DateTime?
  clientId       String?
  projectId      String?      @unique
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  client         Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  project        Project?      @relation
  activities     Activity[]

  @@index([clientId])
  @@index([stage])
}

model Activity {
  id             String        @id @default(cuid())
  type           ActivityType
  title          String
  description    String?
  date           DateTime      @default(now())
  userId         String?
  clientId       String?
  projectId      String?
  taskId         String?
  dealId         String?
  createdAt      DateTime      @default(now())

  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  client         Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  project        Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task           Task?         @relation(fields: [taskId], references: [id], onDelete: SetNull)
  deal           Deal?         @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([clientId])
  @@index([projectId])
  @@index([taskId])
  @@index([dealId])
  @@index([date])
}

model Payment {
  id             String        @id @default(cuid())
  amount         Float
  currency       String        @default("INR")
  status         PaymentStatus @default(PENDING)
  type           PaymentType
  dueDate        DateTime?
  paidAt         DateTime?
  notes          String?
  clientId       String?
  projectId      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  client         Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  project        Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([projectId])
  @@index([status])
  @@index([type])
}

model ActivityLog {
  id          String   @id @default(uuid())
  userId      String
  action      String
  entityType  String?
  entityId    String?
  description String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
}
